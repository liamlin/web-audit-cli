{
  "name": "web-audit-cli",
  "version": "0.3.1",
  "description": "A comprehensive CLI tool, web service, and desktop app for website SEO, performance, and security auditing",
  "type": "module",
  "bin": {
    "web-audit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-templates && npm run copy-public",
    "copy-templates": "mkdir -p dist/modules/reporter/templates && cp -r src/modules/reporter/templates/* dist/modules/reporter/templates/",
    "copy-public": "mkdir -p dist/web/public && cp -r src/web/public/* dist/web/public/",
    "build:electron": "tsc -p tsconfig.electron.json && cp electron/preload.cjs dist-electron/preload.cjs",
    "start:electron": "npm run build && npm run build:electron && electron dist-electron/main.js",
    "pack:mac": "npm run build && npm run build:electron && electron-builder --mac",
    "pack:win": "npm run build && npm run build:electron && electron-builder --win",
    "pack:linux": "npm run build && npm run build:electron && electron-builder --linux",
    "start:web": "node dist/server.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,js}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,js}\"",
    "commit": "cz",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run test",
    "prepare": "husky"
  },
  "keywords": [
    "seo",
    "performance",
    "security",
    "audit",
    "cli",
    "lighthouse",
    "web-vitals",
    "hono",
    "electron",
    "desktop",
    "web-audit"
  ],
  "author": "Wilson Lin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liamlin/web-audit-cli"
  },
  "homepage": "https://github.com/liamlin/web-audit-cli#readme",
  "bugs": {
    "url": "https://github.com/liamlin/web-audit-cli/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "chrome-launcher": "^1.1.0",
    "commander": "^12.0.0",
    "crawlee": "^3.8.0",
    "fast-xml-parser": "^5.4.1",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "hono": "^4.12.3",
    "inquirer": "^9.2.0",
    "lighthouse": "^12.0.0",
    "lighthouse-logger": "^2.0.1",
    "ora": "^8.0.0",
    "puppeteer": "^22.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "^9.39.2",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.2.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.53.1",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": "prettier --write",
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
